fit = off
spec-type = draft-mtp
spec-draft-n-max = 2
jinja = on
reasoning-preserve = on
no-prefill-assistant = true
reasoning = off
load-on-startup = false
temp = 0.6
top-p = 0.95
top-k = 20
min-p = 0.0
repeat-penalty = 1.05
presence-penalty = 0.0
seed = 3407

