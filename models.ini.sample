# Usage: llama-server --models-preset /models.ini
# A section loads on server start only when `load-on-startup = true`.
# Other sections remain as aliases for on-demand use / record-keeping.

[qwen3.6-27b]
model = /models/Qwen3.6-27B-UD-Q4_K_XL.gguf
parallel = 1
ctx-size = 196608
flash-attn = on
timeout = 1200
main-gpu = 0
tensor-split = 50,50
cache-type-k = q8_0
